    "beam.charge.qe"      :  +1.0      , // for 1-particle, unit=[-qe]: -1 for e, +1 for p
    "beam.charge.C"       : 2.73972e-8 , // for bunch, unit=[C]
    "beam.nparticles"     :   1e4      , // #. of super-particles 
    "beam.u.nucleon"      :   2.0      , // #. of nucleon / particle
    "beam.mass.amu"       : 2.014      , // mass [amu] :  2.014 for D, 1.0 for p, 
    "beam.Ek.MeV/u"       :  20.0      , // kinetic energy [MeV]
    "beam.freq.Hz"        : 36.5e6     , // [Hz]
    "beam.harmonics"      : 4          , // int   rf.freq = h * beam.freq

    "beam.twiss.alpha"    : [   0.0,     0.0,    0.0 ], 
    "beam.twiss.beta"     : [ 7.9083, 3.9808, 442.31 ], // [m/rad] or [m]
    "beam.emittance.geom" : [ 94.312, 93.568,   3.52 ], // [mm mrad] - RMS, geometric

    "sim.max_level"       : 1,           // AMR level
    "sim.n_cell"          : [16,16,16],  // cell size for poisson eq.
    "sim.blocking_factor" : [8],         // blocking factor, list ( size = max_level )

    "sim.nUse.elements"   : null,          // null for all, limit n for int n

    
    // ---------------------------- //
    // --- [2] main's settings  --- //
    // ---------------------------- //
    "mode.linear"         : false,       // linear calc.
    "mode.space_charge"   : "3D" ,       // false or "3D" or "2D" 

    
    // ---------------------------- //
    // --- [3] translate        --- //
    // ---------------------------- //
    "translate.quad.skip"             : false,       // skip Q-magnet
    "translate.drift.skip"            : false,       // skip Drift
    "translate.cavity.skip"           : false,       // skip Cavity
    
    "translate.cavity.type"           : "shortrf",   // [ rfcavity, shortrf ]
    "translate.cavity.rfgap"          : true,        // Trace3D like RFgap ( vertical kick )
    "translate.cavity.length"         : 1.e-5,       // finite length for rfcavity
    "translate.cavity.phase"          : -45.0,       // target phase of the cavity.
    "translate.cavity.phase.fromfile" : null,        // set phase manually, null or filename
